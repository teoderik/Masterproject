    "NCC-NorESM1-M_r1i1p1_CLMcom-ETH-COSMO-crCLIM-v1-1",
}

# ============================================================
# BASIC HELPERS
# ============================================================
def pooled_mean(values):
    return sum(values) / len(values)


def pooled_sd_population(values):
    """
    Population standard deviation, since the full ensemble distribution is
    treated as the reference distribution rather than as a sample estimate.
    """
    mu = pooled_mean(values)
    return math.sqrt(sum((x - mu) ** 2 for x in values) / len(values))


def rmse(errors):
    return math.sqrt(sum(e * e for e in errors) / len(errors))


def deterministic_case_seed(base_seed, region, scenario, variable):
    """
    Make the random stream reproducible and stable per case.
    Avoids dependence on file ordering.
    """
    case_str = f"{region}|{scenario}|{variable}"
    offset = sum((i + 1) * ord(ch) for i, ch in enumerate(case_str))
    return base_seed + offset


def pct_string(k, N):
    return f"{100.0 * k / N:.2f}"


def warning_if_above_half(k, N):
    return "More than 50% of the sample needed to be used" if k > 0.5 * N else ""


# ============================================================
# DATA LOADING
# ============================================================
def parse_case_from_filename(path):
    m = INPUT_FILE_PAT.match(path.name)
    if not m:
        return None
    return m.groupdict()


def load_case_csv_filtered(path, allowed_ensemble_ids):
    """
    Returns:
        region, scenario, variable, member_to_values

    member_to_values is a dict:
        ensemble_id -> list of 30 annual means/anomalies
    """
    info = parse_case_from_filename(path)
    if info is None:
        raise ValueError(f"Unexpected input filename format: {path.name}")

    member_year_values = defaultdict(list)

    with open(path, newline="") as f:
        reader = csv.DictReader(f)
        for row in reader:
            ensemble_id = row["ensemble_id"].strip()

            if ensemble_id not in allowed_ensemble_ids:
                continue

            year = int(row["year"])
            value = float(row["annual_mean"])
            member_year_values[ensemble_id].append((year, value))

    cleaned = {}
    for ensemble_id, yv in member_year_values.items():
        yv_sorted = sorted(yv, key=lambda t: t[0])
        values = [v for _, v in yv_sorted]
        cleaned[ensemble_id] = values

    return info["region"], info["scenario"], info["variable"], cleaned


# ============================================================
# SUBSAMPLING EVALUATION
# ============================================================
def evaluate_case(region, scenario, variable, member_to_values, n_repeats=N_REPEATS):
    """
    Evaluate one case for all k = 1..N.

    Returns:
        detailed_rows, summary_rows
    """
    member_ids = sorted(member_to_values.keys())
    N = len(member_ids)

    if N == 0:
        raise RuntimeError(f"{region}/{scenario}/{variable}: no allowed ensemble members found after filtering.")

    # Basic validation
    bad_members = [m for m, vals in member_to_values.items() if len(vals) != 30]
    if bad_members:
        raise RuntimeError(
            f"{region}/{scenario}/{variable}: some members do not have exactly 30 annual means. "
            f"Examples: {bad_members[:5]}"
        )

    # Full pooled reference distribution
    full_values = []
    for m in member_ids:
        full_values.extend(member_to_values[m])

    full_mean = pooled_mean(full_values)
    full_sd = pooled_sd_population(full_values)

    # Thresholds for this case
    threshold_values = {}
    for thr in THRESHOLDS:
        threshold_values[thr] = {
            "mean": thr * abs(full_mean),
            "sd": thr * full_sd,
        }

    # Deterministic RNG per case
    rng = random.Random(deterministic_case_seed(SEED, region, scenario, variable))

    detailed_rows = []

    # Track minimum acceptable k separately for each threshold and criterion
    min_k = {}
    for thr in THRESHOLDS:
        min_k[thr] = {
            "mean": None,
            "sd": None,
            "both": None,
        }

    for k in range(1, N + 1):
        mean_errors = []
        sd_errors = []

        for _ in range(n_repeats):
            sampled_members = rng.sample(member_ids, k)  # without replacement

            sampled_values = []
            for m in sampled_members:
                sampled_values.extend(member_to_values[m])

            sample_mean = pooled_mean(sampled_values)
            sample_sd = pooled_sd_population(sampled_values)

            mean_errors.append(sample_mean - full_mean)
            sd_errors.append(sample_sd - full_sd)

        rmse_mean = rmse(mean_errors)
        rmse_sd = rmse(sd_errors)

        row = {
            "region": region,
            "scenario": scenario,
            "variable": variable,
            "seed": SEED,
            "n_repeats": n_repeats,
            "full_ensemble_size": N,
            "k": k,
            "full_mean": f"{full_mean:.10f}",
            "full_sd": f"{full_sd:.10f}",
            "rmse_mean": f"{rmse_mean:.10f}",
            "rmse_sd": f"{rmse_sd:.10f}",
        }

        for thr in THRESHOLDS:
            mean_threshold = threshold_values[thr]["mean"]
            sd_threshold = threshold_values[thr]["sd"]

            mean_met = rmse_mean <= mean_threshold
            sd_met = rmse_sd <= sd_threshold
            both_met = mean_met and sd_met

            if min_k[thr]["mean"] is None and mean_met:
                min_k[thr]["mean"] = k
            if min_k[thr]["sd"] is None and sd_met:
                min_k[thr]["sd"] = k
            if min_k[thr]["both"] is None and both_met:
                min_k[thr]["both"] = k

            thr_label = str(int(thr * 100))
            row[f"mean_threshold_{thr_label}pct"] = f"{mean_threshold:.10f}"
            row[f"sd_threshold_{thr_label}pct"] = f"{sd_threshold:.10f}"
            row[f"mean_criterion_met_{thr_label}pct"] = int(mean_met)
            row[f"sd_criterion_met_{thr_label}pct"] = int(sd_met)
            row[f"both_criteria_met_{thr_label}pct"] = int(both_met)

        detailed_rows.append(row)

    # Summary rows: one row per threshold x criterion
    summary_rows = []
    for thr in THRESHOLDS:
        thr_label = str(int(thr * 100))
        for criterion in ["mean", "sd", "both"]:
            k_val = min_k[thr][criterion]

            if criterion == "mean":
                threshold_value = threshold_values[thr]["mean"]
            elif criterion == "sd":
                threshold_value = threshold_values[thr]["sd"]
            else:
                threshold_value = ""

            if k_val is None:
                summary_rows.append(
                    {
                        "region": region,
                        "scenario": scenario,
                        "variable": variable,
                        "seed": SEED,
                        "n_repeats": n_repeats,
                        "full_ensemble_size": N,
                        "full_mean": f"{full_mean:.10f}",
                        "full_sd": f"{full_sd:.10f}",
                        "threshold_percent": thr_label,
                        "criterion": criterion,
                        "threshold_value": f"{threshold_value:.10f}" if threshold_value != "" else "",
                        "minimum_acceptable_k": "",
                        "pct_of_full_sample_used": "",
                        "above_50pct_of_full_sample": "",
                        "warning_message": "No acceptable k found",
                    }
                )
            else:
                summary_rows.append(
                    {
                        "region": region,
                        "scenario": scenario,
                        "variable": variable,
                        "seed": SEED,
                        "n_repeats": n_repeats,
                        "full_ensemble_size": N,
                        "full_mean": f"{full_mean:.10f}",
                        "full_sd": f"{full_sd:.10f}",
                        "threshold_percent": thr_label,
                        "criterion": criterion,
                        "threshold_value": f"{threshold_value:.10f}" if threshold_value != "" else "",
                        "minimum_acceptable_k": k_val,
                        "pct_of_full_sample_used": pct_string(k_val, N),
                        "above_50pct_of_full_sample": int(k_val > 0.5 * N),
                        "warning_message": warning_if_above_half(k_val, N),
                    }
                )

    return detailed_rows, summary_rows


# ============================================================
# MAIN
# ============================================================
def main():
    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    input_files = sorted(INPUT_DIR.glob("annual_means_*.csv"))
    case_files = []

    for p in input_files:
        info = parse_case_from_filename(p)
        if info is not None and info["scenario"] == SCENARIO:
            case_files.append(p)

    if not case_files:
        raise RuntimeError(f"No case files found for scenario {SCENARIO} in {INPUT_DIR}")

    detailed_out = OUTPUT_DIR / "ensemble_evaluation_modified_rcp85_detailed.csv"
    summary_out = OUTPUT_DIR / "ensemble_evaluation_modified_rcp85_summary.csv"
    models_out = OUTPUT_DIR / "ensemble_evaluation_modified_rcp85_models_used.csv"

    all_detailed_rows = []
    all_summary_rows = []
    all_models_rows = []

    print(f"Seed: {SEED}")
    print(f"Input directory: {INPUT_DIR}")
    print(f"Output directory: {OUTPUT_DIR}")
    print(f"Scenario: {SCENARIO}")
    print(f"Repeats per k: {N_REPEATS}")
    print(f"Thresholds: {THRESHOLDS}")
    print(f"Case files found: {len(case_files)}")
    print(f"Allowed ensemble IDs: {len(ALLOWED_ENSEMBLE_IDS)}")

    for path in case_files:
        region, scenario, variable, member_to_values = load_case_csv_filtered(path, ALLOWED_ENSEMBLE_IDS)

        used_models = sorted(member_to_values.keys())
        for model in used_models:
            all_models_rows.append({
                "scenario": scenario,
                "region": region,
                "variable": variable,
                "ensemble_id": model
            })

        print(f"\nEvaluating {region} | {scenario} | {variable} ...")
        print(f"  Allowed models actually found in this case: {len(used_models)}")

        detailed_rows, summary_rows = evaluate_case(
            region=region,
            scenario=scenario,
            variable=variable,
            member_to_values=member_to_values,
            n_repeats=N_REPEATS,
        )

        all_detailed_rows.extend(detailed_rows)
        all_summary_rows.extend(summary_rows)

        row_5_both = next(
            r for r in summary_rows if r["threshold_percent"] == "5" and r["criterion"] == "both"
        )
        row_10_both = next(
            r for r in summary_rows if r["threshold_percent"] == "10" and r["criterion"] == "both"
        )

        print(
            f"  N = {row_5_both['full_ensemble_size']}, "
            f"5% both = {row_5_both['minimum_acceptable_k']}, "
            f"10% both = {row_10_both['minimum_acceptable_k']}"
        )

    all_summary_rows.sort(
        key=lambda r: (
            int(r["threshold_percent"]),
            REGION_ORDER[r["region"]],
            VARIABLE_ORDER[r["variable"]],
            CRITERION_ORDER[r["criterion"]],
        )
    )

    all_models_rows.sort(
        key=lambda r: (
            REGION_ORDER[r["region"]],
            VARIABLE_ORDER[r["variable"]],
            r["ensemble_id"],
        )
    )

    detailed_fields = [
        "region",
        "scenario",
        "variable",
        "seed",
        "n_repeats",
        "full_ensemble_size",
        "k",
        "full_mean",
        "full_sd",
        "rmse_mean",
        "rmse_sd",
        "mean_threshold_5pct",
        "sd_threshold_5pct",
        "mean_criterion_met_5pct",
        "sd_criterion_met_5pct",
        "both_criteria_met_5pct",
        "mean_threshold_10pct",
        "sd_threshold_10pct",
        "mean_criterion_met_10pct",
        "sd_criterion_met_10pct",
        "both_criteria_met_10pct",
    ]

    with open(detailed_out, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=detailed_fields)
        writer.writeheader()
        writer.writerows(all_detailed_rows)

    summary_fields = [
        "region",
        "scenario",
        "variable",
        "seed",
        "n_repeats",
        "full_ensemble_size",
        "full_mean",
        "full_sd",
        "threshold_percent",
        "criterion",
        "threshold_value",
        "minimum_acceptable_k",
        "pct_of_full_sample_used",
        "above_50pct_of_full_sample",
        "warning_message",
    ]

    with open(summary_out, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=summary_fields)
        writer.writeheader()
        writer.writerows(all_summary_rows)

    model_fields = ["scenario", "region", "variable", "ensemble_id"]
    with open(models_out, "w", newline="") as f:
        writer = csv.DictWriter(f, fieldnames=model_fields)
        writer.writeheader()
        writer.writerows(all_models_rows)

    print("\nDone.")
    print(f"Detailed results written to: {detailed_out}")
    print(f"Summary results written to:  {summary_out}")
    print(f"Used models written to:      {models_out}")


if __name__ == "__main__":
    main()
