
#!/usr/bin/env python3
import csv
import math
import random
import re
from pathlib import Path
from collections import defaultdict

# ============================================================
# SETTINGS
# ============================================================
SEED = 1995

INPUT_DIR = Path("/home/sm_geoho/ensemble_eval/output")
OUTPUT_DIR = Path("/home/sm_geoho/ensemble_eval/modified_ensemble")

SCENARIO = "rcp85"

# Number of repeated subsamples for each k
N_REPEATS = 1000

# Acceptable error thresholds
THRESHOLDS = [0.05, 0.10]

# Expected input filename pattern
INPUT_FILE_PAT = re.compile(
    r"^annual_means_(?P<region>region_[123])_(?P<scenario>rcp26|rcp45|rcp85)_(?P<variable>tas|pr)\.csv$"
)

REGION_ORDER = {"region_1": 1, "region_2": 2, "region_3": 3}
VARIABLE_ORDER = {"tas": 1, "pr": 2}
CRITERION_ORDER = {"mean": 1, "sd": 2, "both": 3}

# ============================================================
# ALLOWED MODELS FOR RCP85
# ============================================================
ALLOWED_ENSEMBLE_IDS = {
    "CCCma-CanESM2_r1i1p1_CLMcom-CCLM4-8-17",
    "CCCma-CanESM2_r1i1p1_GERICS-REMO2015",
    "CNRM-CERFACS-CNRM-CM5_r1i1p1_CNRM-ALADIN63",
    "CNRM-CERFACS-CNRM-CM5_r1i1p1_KNMI-RACMO22E",
    "ICHEC-EC-EARTH_r1i1p1_SMHI-RCA4",
    "ICHEC-EC-EARTH_r1i1p1_DMI-HIRHAM5",
    "ICHEC-EC-EARTH_r3i1p1_DMI-HIRHAM5",
    "ICHEC-EC-EARTH_r3i1p1_KNMI-RACMO22E",
    "ICHEC-EC-EARTH_r12i1p1_CLMcom-ETH-COSMO-crCLIM-v1-1",
    "ICHEC-EC-EARTH_r12i1p1_ICTP-RegCM4-6",
    "ICHEC-EC-EARTH_r12i1p1_MOHC-HadREM3-GA7-05",
    "IPSL-IPSL-CM5A-MR_r1i1p1_DMI-HIRHAM5",
    "IPSL-IPSL-CM5A-MR_r1i1p1_IPSL-WRF381P",
    "IPSL-IPSL-CM5A-MR_r1i1p1_KNMI-RACMO22E",
    "MIROC-MIROC5_r1i1p1_CLMcom-CCLM4-8-17",
    "MIROC-MIROC5_r1i1p1_GERICS-REMO2015",
    "MOHC-HadGEM2-ES_r1i1p1_CLMcom-CCLM4-8-17",
    "MOHC-HadGEM2-ES_r1i1p1_CNRM-ALADIN63",
    "MPI-M-MPI-ESM-LR_r1i1p1_MPI-CSC-REMO2009",
    "MPI-M-MPI-ESM-LR_r1i1p1_CNRM-ALADIN63",
    "MPI-M-MPI-ESM-LR_r1i1p1_ICTP-RegCM4-6",
    "MPI-M-MPI-ESM-LR_r2i1p1_MPI-CSC-REMO2009",
